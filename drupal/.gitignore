# 作用：告诉 Git 哪些文件不需要传到 GitHub（比如缓存、日志、敏感数据）

# 操作系统自动生成的文件
.DS_Store
Thumbs.db

# 依赖库目录（由服务器端 Composer 和 Npm 独立管理）
vendor/
node_modules/

# 临时文件和日志
*.log
*.tar.gz
*.sql
*.bak
*.swp

# IDE 和编辑器配置
.idea/
.vscode/
*.sublime-workspace

# 前端构建的产物（假设未来如果用到 webpack/vite，其输出不要提交，直接在服务器构建）
dist/
build/
.cache/
