{# 
  文件：page--front.html.twig
  要求：图片主导 / 大留白 py-16 / 动态 Views 数据 / 极致交互
#}

<div class="min-h-screen bg-zinc-50 dark:bg-zinc-950 text-zinc-900 dark:text-zinc-100 font-sans">

  {# ========================================== #}
  {# 1. 顶部导航 (Sticky + Blur) #}
  {# ========================================== #}
  <header class="sticky top-0 z-50 w-full border-b border-zinc-200 dark:border-zinc-800 bg-white/70 dark:bg-zinc-950/70 backdrop-blur-lg transition-all">
    <div class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-xl bg-zinc-900 dark:bg-white flex items-center justify-center text-white dark:text-zinc-900 font-bold text-lg shadow-sm">M</div>
        <span class="text-xl font-extrabold tracking-tight">XXEDC</span>
      </div>
      <nav class="hidden md:flex items-center gap-8 font-medium text-sm text-zinc-500 dark:text-zinc-400">
        <a href="/" class="text-zinc-900 dark:text-white font-semibold">推荐</a>
        <a href="#" class="hover:text-zinc-900 dark:hover:text-white transition-colors">图集</a>
        <a href="#" class="hover:text-zinc-900 dark:hover:text-white transition-colors">视频</a>
        <a href="#" class="hover:text-zinc-900 dark:hover:text-white transition-colors">专栏</a>
      </nav>
      <div class="flex items-center gap-4">
        <button class="w-9 h-9 flex items-center justify-center rounded-full hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </button>
        <a href="/user" class="rounded-full bg-zinc-900 dark:bg-white text-white dark:text-zinc-900 px-5 py-2 text-sm font-semibold hover:bg-zinc-800 dark:hover:bg-zinc-200 transition-all shadow-sm">
          登录
        </a>
      </div>
    </div>
  </header>

  <main>
    {# ========================================== #}
    {# 2. 最新图集 (核心模块 - Pinterest 网格) #}
    {# ========================================== #}
    <section class="max-w-7xl mx-auto px-4 py-16">
      <div class="flex items-end justify-between mb-10">
        <div>
          <h2 class="text-3xl font-extrabold tracking-tight mb-2">最新图集</h2>
          <p class="text-sm text-zinc-500">每日更新的高质量美女写真资源</p>
        </div>
        <a href="#" class="text-sm font-medium text-zinc-500 hover:text-zinc-900 dark:hover:text-white transition-colors flex items-center group">
          查看更多 <svg class="w-4 h-4 ml-1 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </a>
      </div>
      
      {# 动态调用 Drupal Views: front_gallery #}
      <div class="drupal-dynamic-gallery">
        {{ drupal_view('front_gallery', 'block_1') }}
      </div>
    </section>

    {# ========================================== #}
    {# 3. 热门视频 (横向滑动展现) #}
    {# ========================================== #}
    <section class="border-t border-zinc-200 dark:border-zinc-800/50 bg-white dark:bg-zinc-950">
      <div class="max-w-7xl mx-auto px-4 py-16">
        <div class="flex items-end justify-between mb-10">
          <div>
            <h2 class="text-3xl font-extrabold tracking-tight mb-2">热门视频</h2>
            <p class="text-sm text-zinc-500">沉浸式高清视频体验</p>
          </div>
        </div>
        
        {# 动态调用 Drupal Views: front_video #}
        <div class="drupal-dynamic-video">
          {{ drupal_view('front_video', 'block_1') }}
        </div>
      </div>
    </section>

    {# ========================================== #}
    {# 4. 推荐文章 (极简图文列表) #}
    {# ========================================== #}
    <section class="border-t border-zinc-200 dark:border-zinc-800/50 bg-zinc-50 dark:bg-zinc-900/20">
      <div class="max-w-7xl mx-auto px-4 py-16">
        <h2 class="text-3xl font-extrabold tracking-tight mb-10">推荐专栏</h2>
        
        {# 动态调用 Drupal Views: front_article #}
        <div class="drupal-dynamic-article">
          {{ drupal_view('front_article', 'block_1') }}
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-950 py-12">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <p class="text-zinc-500 text-sm">© 2026 XXEDC Content Hub. All rights reserved.</p>
    </div>
  </footer>

  {# ========================================== #}
  {# 引擎级 CSS 强制覆写：将 Drupal 杂乱的 DOM 强行扭转为你要求的高级卡片规范 #}
  {# ========================================== #}
  <style>
    /* 隐藏所有多余的滚条 */
    ::-webkit-scrollbar { display: none; }
    
    /* --- 图集网格 (Pinterest 风格) --- */
    .drupal-dynamic-gallery .view-content {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.5rem;
    }
    .drupal-dynamic-gallery .views-row {
      position: relative;
      border-radius: 0.75rem; /* rounded-xl */
      overflow: hidden;
      box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); /* shadow-sm */
      aspect-ratio: 3 / 4; /* aspect-[3/4] */
      transition: all 0.3s ease; /* transition-all duration-300 */
      background-color: #18181b;
    }
    .drupal-dynamic-gallery .views-row:hover {
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05); /* hover:shadow-lg */
      transform: translateY(-4px);
    }
    .drupal-dynamic-gallery .views-row img {
      width: 100%;
      height: 100%;
      object-fit: cover; /* object-cover */
      transition: transform 0.5s ease;
    }
    .drupal-dynamic-gallery .views-row:hover img {
      transform: scale(1.05); /* hover:scale-105 */
    }
    /* 强行把标题悬浮在图片上方 */
    .drupal-dynamic-gallery .views-row h2 {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 3rem 1rem 1rem;
      background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);
      color: white;
      font-size: 1.125rem;
      font-weight: 700;
      margin: 0;
      z-index: 10;
    }

    /* --- 视频横滑 (Carousel 风格) --- */
    .drupal-dynamic-video .view-content {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: 1.5rem;
      padding-bottom: 1rem;
    }
    .drupal-dynamic-video .views-row {
      flex-shrink: 0;
      width: 85%;
      max-width: 480px;
      scroll-snap-align: start;
      position: relative;
      border-radius: 0.75rem;
      overflow: hidden;
      box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05);
      aspect-ratio: 16 / 9; /* aspect-video */
      transition: all 0.3s ease;
      background-color: #000;
    }
    .drupal-dynamic-video .views-row:hover {
      box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
    }
    .drupal-dynamic-video .views-row img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.8;
      transition: transform 0.5s ease;
    }
    .drupal-dynamic-video .views-row:hover img {
      transform: scale(1.05);
      opacity: 1;
    }
    .drupal-dynamic-video .views-row h2 {
      position: absolute;
      bottom: 0;
      width: 100%;
      padding: 2rem 1rem 1rem;
      background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);
      color: white;
      font-size: 1.125rem;
      font-weight: 700;
      margin: 0;
    }

    /* --- 文章列表 (左图右文风格) --- */
    .drupal-dynamic-article .view-content {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
      gap: 1.5rem;
    }
    .drupal-dynamic-article .views-row {
      display: flex;
      gap: 1rem;
      padding: 1rem;
      border-radius: 0.75rem;
      background-color: white;
      border: 1px solid #e5e7eb; /* subtle border */
      box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05);
      transition: all 0.3s ease;
    }
    .dark .drupal-dynamic-article .views-row {
      background-color: #18181b;
      border-color: #27272a;
    }
    .drupal-dynamic-article .views-row:hover {
      box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
      transform: translateY(-2px);
    }
    .drupal-dynamic-article .views-row img {
      width: 6rem;
      height: 6rem;
      border-radius: 0.5rem;
      object-fit: cover;
    }
    .drupal-dynamic-article .views-row h2 {
      font-size: 1rem;
      font-weight: 700;
      margin: 0 0 0.5rem 0;
    }

    /* 暴力隐藏 Drupal 默认多余的日期、作者等元素，保持极简 */
    .node__meta, .node__submitted, .links { display: none !important; }
  </style>
</div>
