{# paragraph--code-block.html.twig — 代码块（集成 Prism.js）#}
{% set lang = paragraph.field_language.value|default('bash') %}
{% set filename = paragraph.field_filename.value|default('') %}

<figure{{ attributes.addClass('xedc-paragraph', 'xedc-paragraph--code') }}>
  {% if filename %}
    <figcaption class="xedc-code__filename">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:inline;vertical-align:middle;">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
      </svg>
      {{ filename }}
    </figcaption>
  {% endif %}
  <div class="xedc-code__wrap">
    <button class="xedc-code__copy" aria-label="复制代码" title="复制">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
      </svg>
    </button>
    <pre class="language-{{ lang }}"><code class="language-{{ lang }}">{{ paragraph.field_code.value }}</code></pre>
  </div>
</figure>
