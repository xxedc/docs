{#
  node--article--full.html.twig — 文章详情页
  阅读进度条 + 目录锚点 + 正文 Paragraphs
#}
{% set nid = node.id() %}

{# 阅读进度条（固定顶部）#}
<div class="xedc-reading-progress" id="xedc-reading-progress" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
  <div class="xedc-reading-progress__bar" id="xedc-progress-bar"></div>
</div>

<div class="xedc-article-detail">
  <div class="xedc-container">
    <div class="xedc-article-detail__layout">

      {# ── 左侧目录（PC端）── #}
      <aside class="xedc-article-detail__toc" id="xedc-toc-sidebar">
        <div class="xedc-toc" id="xedc-toc">
          <div class="xedc-toc__title">目录</div>
          <div class="xedc-toc__list" id="xedc-toc-list">
            {# JS 自动生成 #}
          </div>
        </div>
      </aside>

      {# ── 主内容区 ── #}
      <article{{ attributes.addClass('xedc-article-detail__main') }}>

        {# 文章头部 #}
        <header class="xedc-article-detail__header">
          <h1 class="xedc-article-detail__title">{{ label }}</h1>

          {# 摘要 #}
          {% if node.field_summary.value %}
            <p class="xedc-article-detail__summary">{{ node.field_summary.value }}</p>
          {% endif %}

          {# 作者 + 元信息 #}
          <div class="xedc-article-detail__meta xedc-flex xedc-items-center xedc-gap-4">
            <div class="xedc-flex xedc-items-center xedc-gap-2">
              <div class="xedc-avatar xedc-avatar--sm">
                <span class="xedc-avatar__fallback">
                  {{ node.getOwner().getDisplayName()|slice(0,1)|upper }}
                </span>
              </div>
              <a href="/user/{{ node.getOwnerId() }}" class="xedc-text-sm">
                {{ node.getOwner().getDisplayName() }}
              </a>
            </div>
            <span class="xedc-text-sm xedc-text-muted">
              {{ node.getCreatedTime()|date('Y年m月d日') }}
            </span>
            {% if node.field_reading_time.value %}
              <span class="xedc-text-sm xedc-text-muted">
                📖 约 {{ node.field_reading_time.value }} 分钟阅读
              </span>
            {% endif %}
            <span class="xedc-text-sm xedc-text-muted">👁 {{ view_count|default(0) }}</span>
          </div>

          {# 分类标签 #}
          {% if content.field_tags %}
            <div class="xedc-flex xedc-gap-2" style="flex-wrap:wrap; margin-top: var(--space-3);">
              {{ content.field_tags }}
            </div>
          {% endif %}
        </header>

        {# 封面图 #}
        {% if content.field_cover_image|render|trim is not empty %}
          <div class="xedc-article-detail__cover">
            {{ content.field_cover_image }}
          </div>
        {% endif %}

        {# 正文 Paragraphs（核心）#}
        <div class="xedc-article__body" id="xedc-article-body">
          {{ content.field_body_paragraphs }}
          {# 兼容旧版 body 字段 #}
          {% if content.body|render|trim is not empty %}
            {{ content.body }}
          {% endif %}
        </div>

        {# 文末互动 #}
        <div class="xedc-article-detail__bottom-actions xedc-flex xedc-items-center xedc-gap-3">
          <button class="xedc-action-btn xedc-like-btn" data-nid="{{ nid }}">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
            {{ like_count|default(0) }} 点赞
          </button>
          <button class="xedc-action-btn xedc-collect-btn" data-nid="{{ nid }}">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
            </svg>
            收藏
          </button>
          <button class="xedc-action-btn"
            onclick="navigator.clipboard.writeText(window.location.href);alert('链接已复制')">
            分享
          </button>
        </div>

        {# 作者卡片 #}
        <div class="xedc-author-card xedc-card">
          <div class="xedc-card__body xedc-flex xedc-items-center xedc-gap-4">
            <div class="xedc-avatar xedc-avatar--lg">
              <span class="xedc-avatar__fallback">
                {{ node.getOwner().getDisplayName()|slice(0,1)|upper }}
              </span>
            </div>
            <div>
              <a href="/user/{{ node.getOwnerId() }}" class="xedc-author-card__name">
                {{ node.getOwner().getDisplayName() }}
              </a>
              <p class="xedc-text-sm xedc-text-muted" style="margin-top:var(--space-1);">作者主页</p>
            </div>
            <a href="/user/{{ node.getOwnerId() }}"
               class="xedc-btn xedc-btn--outline xedc-btn--sm"
               style="margin-left:auto;">
              查看主页
            </a>
          </div>
        </div>

        {# 相关文章 #}
        <div class="xedc-article-detail__related" style="margin-top: var(--space-8);">
          <h3 class="xedc-sidebar__title">相关推荐</h3>
          {{ drupal_view('article_list', 'block_1') }}
        </div>

        {# 评论区 #}
        <div class="xedc-comments" id="xedc-comments" style="margin-top: var(--space-8);">
          <h3 class="xedc-comments__title">评论</h3>
          {% if is_logged_in %}
            <div class="xedc-comment-form">
              <textarea class="xedc-input" style="height:100px;resize:vertical;width:100%;"
                placeholder="写下你的想法... 支持 Markdown"></textarea>
              <button class="xedc-btn xedc-btn--default xedc-btn--sm"
                style="margin-top:var(--space-2);"
                onclick="alert('评论功能阶段4完善')">
                发表评论
              </button>
            </div>
          {% else %}
            <p class="xedc-text-sm xedc-text-muted">
              <a href="/user/login">登录</a>后发表评论
            </p>
          {% endif %}
        </div>

      </article>

    </div>
  </div>
</div>

{# 阅读控制面板（浮动右下角）#}
<div class="xedc-reading-controls" id="xedc-reading-controls">
  <button class="xedc-reading-controls__btn" id="xedc-font-decrease" title="缩小字体" aria-label="缩小字体">A-</button>
  <button class="xedc-reading-controls__btn" id="xedc-font-increase" title="放大字体" aria-label="放大字体">A+</button>
  <button class="xedc-reading-controls__btn" id="xedc-focus-mode" title="专注模式" aria-label="专注模式">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M8 3H5a2 2 0 0 0-2 2v3"/><path d="M21 8V5a2 2 0 0 0-2-2h-3"/>
      <path d="M3 16v3a2 2 0 0 0 2 2h3"/><path d="M16 21h3a2 2 0 0 0 2-2v-3"/>
    </svg>
  </button>
</div>
