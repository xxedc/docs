{#
  html.html.twig — HTML 根模板
  theme-init.js 在此同步执行，防止闪白（FOUC）
#}
<!DOCTYPE html>
<html{{ html_attributes }}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  {{ head }}
  {# 防闪烁初始化脚本（同步执行，不能 defer）#}
  <script>
    (function(){
      var k='xedc-theme';
      var s='light';
      try{ s=localStorage.getItem(k)||'system'; }catch(e){}
      if(s==='system'||s===''){
        s=window.matchMedia&&window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light';
      }
      document.documentElement.setAttribute('data-theme',s);
    })();
  </script>
  {{ styles }}
</head>
<body{{ attributes }}>
  {{ page_top }}
  {{ page }}
  {{ page_bottom }}
  {{ scripts }}
</body>
</html>
